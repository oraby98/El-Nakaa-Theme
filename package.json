{
  "name": "qtc",
  "version": "3.0.2",
  "description": "The simplest WordPress starter theme including full setup for Tailwind CSS, Sass, PostCSS, Autoprefixer, Vite, TypeScript, Browsersync, imagemin, Prettier, stylelint, ESLint.",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "Firefox ESR"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:vite": "vite",
    "dev:css": "npx @tailwindcss/cli -i src/style.css -o assets/css/main.css --watch",
    "build": "npm-run-all --parallel build:*",
    "build:vite": "vite build",
    "build:css": "npx @tailwindcss/cli -i src/style.css -o assets/css/main.css --minify",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wp-bathe/bathe.git"
  },
  "keywords": [
    "WordPress",
    "vite",
    "tailwindcss"
  ],
  "author": "Kite",
  "license": "GPL-2.0+",
  "bugs": {
    "url": "https://github.com/wp-bathe/bathe/issues"
  },
  "homepage": "https://github.com/wp-bathe/bathe",
  "engines": {
    "node": ">= 18.16",
    "npm": ">= 9.5"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@ixkaito/imagemin": "^0.1.0",
    "@tailwindcss/cli": "^4.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint": "^8.43.0",
    "globby": "^13.2.0",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-jpegtran": "^7.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-svgo": "^10.0.1",
    "npm-run-all": "^4.1.5",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.1.3",
    "vite": "^6.0.0"
  }
}
